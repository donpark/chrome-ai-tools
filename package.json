{
  "name": "chrome-ai-tools",
  "version": "0.1.0",
  "description": "Call Chrome's built-in AI APIs (Gemini Nano) from Node.js",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "chrome-ai": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "!dist/test*",
    "SKILL.md",
    "server.py",
    "client.py"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "node --test dist/test.js && python3 test.py"
  },
  "repository": "github:donpark/chrome-ai-tools",
  "keywords": [
    "chrome",
    "gemini",
    "gemini-nano",
    "ai",
    "prompt-api",
    "language-model"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5"
  }
}
