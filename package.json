{
  "name": "chrome-ai",
  "version": "0.1.0",
  "description": "Call Chrome's built-in AI APIs (Gemini Nano) from Node.js",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": ["dist/", "SKILL.md"],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "prepublishOnly": "tsc"
  },
  "repository": "github:donpark/chrome-ai",
  "keywords": ["chrome", "gemini", "gemini-nano", "ai", "prompt-api", "language-model"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5"
  }
}
